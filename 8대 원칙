import React, { useState, useEffect } from 'react';
import { 
  ShieldCheck, 
  Search, 
  UserCheck, 
  Clock, 
  FileText, 
  AlertTriangle, 
  Layers, 
  CheckCircle,
  ArrowLeft,
  BookOpen,
  Trophy,
  User,
  Hash
} from 'lucide-react';

const App = () => {
  const [view, setView] = useState('home'); // home, learning, quiz-setup, quiz
  const [selectedPrinciple, setSelectedPrinciple] = useState(null);
  const [userInfo, setUserInfo] = useState({ studentId: '', name: '' });
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);
  const [attempts, setAttempts] = useState(1);
  const [totalScore, setTotalScore] = useState(0);
  const [quizFeedback, setQuizFeedback] = useState(null);
  const [isCorrect, setIsCorrect] = useState(false);

  // 8대 팩트체크 원칙 데이터
  const principles = [
    {
      id: 1,
      title: "출처의 투명성",
      icon: <Search className="w-8 h-8" />,
      description: "정보를 전달하는 사람이나 매체가 어디서 이 정보를 얻었는지 명확하게 밝히고 있나요?",
      example: "뉴스 기사 하단에 보도자료 출처나 인터뷰 대상자의 실명이 구체적으로 적혀 있는지 확인합니다.",
      hint: "정보의 '뿌리'가 어디인지 확인하는 것이 중요해요."
    },
    {
      id: 2,
      title: "근거의 객관성",
      icon: <FileText className="w-8 h-8" />,
      description: "개인적인 주장이나 감정이 아닌, 통계, 데이터, 논문 등 객관적인 수치로 증명되었나요?",
      example: "'사람들이 싫어한다'는 말 대신 '설문조사 결과 응답자의 70%가 반대했다'는 데이터를 확인합니다.",
      hint: "주관적인 느낌보다 숫자로 된 증거를 찾아보세요."
    },
    {
      id: 3,
      title: "작성자의 전문성",
      icon: <UserCheck className="w-8 h-8" />,
      description: "해당 분야를 잘 아는 전문가나 공신력 있는 기관에서 발표한 내용인가요?",
      example: "건강 정보라면 의사나 보건복지부의 자료인지, 익명의 커뮤니티 글인지 구분합니다.",
      hint: "이 이야기를 누가 했는지, 그 분야의 전문가인지 보세요."
    },
    {
      id: 4,
      title: "정보의 최신성",
      icon: <Clock className="w-8 h-8" />,
      description: "너무 오래된 자료를 마치 최근에 일어난 일처럼 공유하고 있지는 않나요?",
      example: "3년 전 기사를 오늘 날짜의 뉴스처럼 퍼나르는 것은 왜곡된 사실을 전달할 수 있습니다.",
      hint: "날짜를 확인해보세요. 지금 상황과 맞는 정보인가요?"
    },
    {
      id: 5,
      title: "교차 검증",
      icon: <Layers className="w-8 h-8" />,
      description: "하나의 매체뿐만 아니라 다른 신뢰할 수 있는 여러 매체에서도 동일하게 보도하고 있나요?",
      example: "자극적인 속보가 떴을 때, 공영방송이나 대형 언론사 3곳 이상에서 다루는지 검색해봅니다.",
      hint: "다른 곳에서도 똑같이 말하고 있는지 비교해보세요."
    },
    {
      id: 6,
      title: "맥락의 정확성",
      icon: <AlertTriangle className="w-8 h-8" />,
      description: "전체 내용 중 일부만 잘라내어 본래의 의도를 왜곡하지 않았나요? (일명 '악마의 편집')",
      example: "정치인의 발언 중 앞뒤를 다 자르고 자극적인 문구 하나만 퍼뜨리는 경우를 경계합니다.",
      hint: "앞뒤 사정을 다 살펴봐야 정확한 뜻을 알 수 있어요."
    },
    {
      id: 7,
      title: "이미지/영상 진위",
      icon: <ShieldCheck className="w-8 h-8" />,
      description: "사진이나 영상이 합성되었거나, 다른 사건의 자료를 도용하지 않았나요?",
      example: "해외 재난 사진을 한국의 사고 현장인 것처럼 올리는 가짜 뉴스를 구글 이미지 검색으로 확인합니다.",
      hint: "눈에 보이는 화면이 진짜 그 현장의 모습인지 의심해보세요."
    },
    {
      id: 8,
      title: "편향성 확인",
      icon: <CheckCircle className="w-8 h-8" />,
      description: "특정 집단의 이익을 대변하거나 선동하기 위해 한쪽 입장만 편파적으로 담지는 않았나요?",
      example: "광고성 기사인데 정보성 기사인 척하거나, 특정 후보를 비방하기 위한 목적인지 분석합니다.",
      hint: "정보를 만든 사람이 한쪽 편만 들고 있지는 않은가요?"
    }
  ];

  // 퀴즈 데이터
  const quizData = [
    {
      question: "유명 연예인이 불법 도박을 했다는 SNS 글을 봤어. 게시글에는 출처가 없고 '지인에게 들었다'고만 적혀 있어. 이때 가장 먼저 의심해야 할 원칙은?",
      answer: 1, // 출처의 투명성
      explanation: "정보의 근원지가 명확하지 않으므로 '출처의 투명성' 원칙에 어긋납니다."
    },
    {
      question: "오늘 내린 폭우 상황이라며 단톡방에 사진이 올라왔어. 그런데 구글 이미지 검색을 해보니 5년 전 일본에서 찍힌 사진이야. 어떤 원칙 위반일까?",
      answer: 7, // 이미지/영상 진위
      exampleAnswer: 4, // 최신성도 중복될 수 있으나 이미지가 핵심
      correctOptions: [7, 4],
      answerText: "이미지/영상 진위 또는 최신성"
    },
    {
      question: "정부 정책에 대해 '국민 모두가 반대한다'는 기사를 봤어. 기사 안에는 구체적인 설문 데이터나 수치가 전혀 없었지. 무엇이 부족할까?",
      answer: 2, // 근거의 객관성
      explanation: "막연한 주장이 아닌 구체적인 데이터가 필요합니다."
    },
    {
      question: "유튜브에서 한 의학 정보를 봤는데, 발표자가 의사가 아니라 일반 유튜버였어. 이 정보의 신뢰도를 판단할 때 중요한 원칙은?",
      answer: 3, // 작성자의 전문성
      explanation: "전문 지식을 다루는 정보는 작성자의 자격과 전문성이 중요합니다."
    },
    {
      question: "한 뉴스에서 정치인의 발언을 3초만 보여주며 비난했어. 알고보니 전체 1시간 연설 중 농담조로 한 말이었지. 어떤 원칙을 지키지 않았을까?",
      answer: 6, // 맥락의 정확성
      explanation: "의도적으로 일부분만 발췌하여 왜곡하는 것은 맥락을 해치는 행위입니다."
    }
  ];

  const handleStartQuiz = () => {
    if (userInfo.studentId.length === 5 && userInfo.name.trim() !== '') {
      setView('quiz');
    } else {
      alert("학번(숫자 5자리)과 이름을 정확히 입력해주세요.");
    }
  };

  const calculatePoints = (currentAttempts) => {
    if (currentAttempts === 1) return 30;
    if (currentAttempts === 2) return 20;
    if (currentAttempts === 3) return 10;
    return 5;
  };

  const handleAnswerSubmit = (principleId) => {
    const currentQuiz = quizData[currentQuestionIndex];
    const isAnswerCorrect = Array.isArray(currentQuiz.correctOptions) 
      ? currentQuiz.correctOptions.includes(principleId)
      : currentQuiz.answer === principleId;

    if (isAnswerCorrect) {
      const points = calculatePoints(attempts);
      setTotalScore(prev => prev + points);
      setIsCorrect(true);
      setQuizFeedback(`정답입니다! (+${points}점)`);
    } else {
      setAttempts(prev => prev + 1);
      setQuizFeedback(`틀렸습니다. 힌트: ${principles.find(p => p.id === (currentQuiz.answer || currentQuiz.correctOptions[0])).hint}`);
    }
  };

  const nextQuestion = () => {
    if (currentQuestionIndex < quizData.length - 1) {
      setCurrentQuestionIndex(prev => prev + 1);
      setAttempts(1);
      setIsCorrect(false);
      setQuizFeedback(null);
    } else {
      setView('result');
    }
  };

  const goBackQuiz = () => {
    if (currentQuestionIndex > 0) {
      setCurrentQuestionIndex(prev => prev - 1);
      setAttempts(1);
      setIsCorrect(false);
      setQuizFeedback(null);
    } else {
      setView('quiz-setup');
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans p-4 md:p-8">
      <div className="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
        
        {/* Header */}
        <header className="bg-indigo-600 text-white p-6 flex justify-between items-center">
          <div>
            <h1 className="text-2xl font-bold flex items-center gap-2">
              <ShieldCheck className="w-8 h-8" />
              팩트체크 챌린지
            </h1>
            <p className="text-indigo-100 text-sm mt-1">미디어 리터러시: 가짜 뉴스를 찾아라!</p>
          </div>
          {view === 'quiz' && (
            <div className="text-right">
              <p className="text-xs opacity-80">{userInfo.studentId} {userInfo.name}</p>
              <p className="text-xl font-mono font-bold">{totalScore}점</p>
            </div>
          )}
        </header>

        {/* View: Home */}
        {view === 'home' && (
          <div className="p-8 text-center">
            <div className="mb-8">
              <img 
                src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&q=80&w=800" 
                alt="Media Literacy" 
                className="w-full h-48 object-cover rounded-2xl mb-6 shadow-md"
                onError={(e) => e.target.src = 'https://via.placeholder.com/800x400?text=Media+Literacy'}
              />
              <h2 className="text-3xl font-extrabold text-slate-800 mb-4">가짜 뉴스의 시대, 당신은 팩트체커인가요?</h2>
              <p className="text-slate-600 leading-relaxed max-w-2xl mx-auto">
                우리는 매일 엄청난 양의 정보 속에서 살아갑니다. 무엇이 진실이고 무엇이 거짓인지 
                판단하는 능력인 '미디어 리터러시'는 현대인의 필수 역량입니다. 
                먼저 팩트체크의 8대 원칙을 배우고, 실전 챌린지에 도전해보세요!
              </p>
            </div>
            <button 
              onClick={() => setView('learning')}
              className="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-bold text-lg hover:bg-indigo-700 transition-all transform hover:scale-105 shadow-lg flex items-center gap-2 mx-auto"
            >
              <BookOpen className="w-5 h-5" />
              8대 원칙 학습 시작하기
            </button>
          </div>
        )}

        {/* View: Learning (8 Principles) */}
        {view === 'learning' && (
          <div className="p-8">
            <div className="flex items-center justify-between mb-8">
              <h2 className="text-2xl font-bold text-slate-800">팩트체크 8대 원칙</h2>
              <button 
                onClick={() => setView('home')}
                className="text-slate-500 hover:text-slate-800 flex items-center gap-1 text-sm font-medium"
              >
                <ArrowLeft className="w-4 h-4" /> 처음으로
              </button>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              {principles.map((p) => (
                <button
                  key={p.id}
                  onClick={() => setSelectedPrinciple(p)}
                  className={`flex items-center gap-4 p-5 rounded-2xl border-2 text-left transition-all ${
                    selectedPrinciple?.id === p.id 
                    ? 'border-indigo-500 bg-indigo-50 shadow-inner' 
                    : 'border-slate-100 hover:border-indigo-200 hover:bg-slate-50'
                  }`}
                >
                  <div className={`p-3 rounded-xl ${selectedPrinciple?.id === p.id ? 'bg-indigo-600 text-white' : 'bg-slate-100 text-slate-500'}`}>
                    {p.icon}
                  </div>
                  <div>
                    <h3 className="font-bold text-lg">{p.title}</h3>
                    <p className="text-xs text-slate-500">원칙 {p.id}</p>
                  </div>
                </button>
              ))}
            </div>

            {selectedPrinciple ? (
              <div className="bg-indigo-50 rounded-3xl p-8 border border-indigo-100 animate-in fade-in slide-in-from-bottom-4 duration-300">
                <div className="flex items-start gap-4 mb-4">
                  <div className="p-3 bg-indigo-600 text-white rounded-2xl">
                    {selectedPrinciple.icon}
                  </div>
                  <div>
                    <h3 className="text-2xl font-bold text-indigo-900">{selectedPrinciple.title}</h3>
                    <p className="text-indigo-600 font-medium">상세 설명</p>
                  </div>
                </div>
                <p className="text-lg text-slate-700 mb-6 leading-relaxed">
                  {selectedPrinciple.description}
                </p>
                <div className="bg-white rounded-2xl p-6 border border-indigo-200 shadow-sm">
                  <h4 className="font-bold text-slate-800 mb-2 flex items-center gap-2">
                    <CheckCircle className="w-5 h-5 text-green-500" />
                    현실 예시
                  </h4>
                  <p className="text-slate-600 italic">
                    "{selectedPrinciple.example}"
                  </p>
                </div>
              </div>
            ) : (
              <div className="text-center p-12 border-2 border-dashed border-slate-200 rounded-3xl">
                <p className="text-slate-400">원칙을 클릭하여 상세 내용과 예시를 확인해보세요.</p>
              </div>
            )}

            <div className="mt-10 flex justify-center">
              <button 
                onClick={() => setView('quiz-setup')}
                className="px-10 py-4 bg-slate-800 text-white rounded-2xl font-bold text-lg hover:bg-slate-900 transition-all flex items-center gap-2"
              >
                도전! 팩트체크 챌린지
              </button>
            </div>
          </div>
        )}

        {/* View: Quiz Setup */}
        {view === 'quiz-setup' && (
          <div className="p-8 max-w-md mx-auto">
            <h2 className="text-2xl font-bold text-center mb-8">도전자 정보 입력</h2>
            <div className="space-y-6">
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                  <Hash className="w-4 h-4" /> 학번 (숫자 5자리)
                </label>
                <input 
                  type="text" 
                  maxLength={5}
                  value={userInfo.studentId}
                  onChange={(e) => setUserInfo({...userInfo, studentId: e.target.value.replace(/[^0-9]/g, '')})}
                  placeholder="예: 20101"
                  className="w-full p-4 border-2 border-slate-200 rounded-2xl focus:border-indigo-500 focus:outline-none text-lg font-mono tracking-widest"
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                  <User className="w-4 h-4" /> 이름
                </label>
                <input 
                  type="text" 
                  value={userInfo.name}
                  onChange={(e) => setUserInfo({...userInfo, name: e.target.value})}
                  placeholder="실명을 입력해주세요"
                  className="w-full p-4 border-2 border-slate-200 rounded-2xl focus:border-indigo-500 focus:outline-none text-lg"
                />
              </div>
              <div className="pt-4 flex gap-4">
                <button 
                  onClick={() => setView('learning')}
                  className="flex-1 py-4 border-2 border-slate-200 rounded-2xl font-bold text-slate-600 hover:bg-slate-50 transition-all"
                >
                  학습으로 돌아가기
                </button>
                <button 
                  onClick={handleStartQuiz}
                  className="flex-[2] py-4 bg-indigo-600 text-white rounded-2xl font-bold text-lg hover:bg-indigo-700 shadow-lg shadow-indigo-200"
                >
                  챌린지 시작
                </button>
              </div>
            </div>
          </div>
        )}

        {/* View: Quiz */}
        {view === 'quiz' && (
          <div className="p-6 md:p-8">
            <div className="flex justify-between items-center mb-6">
              <span className="bg-slate-100 px-4 py-1 rounded-full text-sm font-bold text-slate-600">
                문제 {currentQuestionIndex + 1} / {quizData.length}
              </span>
              <button 
                onClick={() => setView('learning')}
                className="text-indigo-600 hover:underline text-sm font-bold flex items-center gap-1"
              >
                <BookOpen className="w-4 h-4" /> 8대 원칙 다시보기
              </button>
            </div>

            <div className="mb-8">
              <h3 className="text-xl font-bold text-slate-800 leading-snug">
                {quizData[currentQuestionIndex].question}
              </h3>
            </div>

            {quizFeedback && (
              <div className={`mb-6 p-4 rounded-2xl flex items-start gap-3 border ${
                isCorrect ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800'
              }`}>
                {isCorrect ? <CheckCircle className="w-5 h-5 flex-shrink-0" /> : <AlertTriangle className="w-5 h-5 flex-shrink-0" />}
                <p className="font-medium">{quizFeedback}</p>
              </div>
            )}

            <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
              {principles.map((p) => (
                <button
                  key={p.id}
                  disabled={isCorrect}
                  onClick={() => handleAnswerSubmit(p.id)}
                  className={`p-4 rounded-xl border-2 transition-all text-left flex items-center gap-3 ${
                    isCorrect && (Array.isArray(quizData[currentQuestionIndex].correctOptions) 
                      ? quizData[currentQuestionIndex].correctOptions.includes(p.id) 
                      : quizData[currentQuestionIndex].answer === p.id)
                    ? 'border-green-500 bg-green-50 text-green-700'
                    : isCorrect 
                      ? 'border-slate-100 opacity-50' 
                      : 'border-slate-100 hover:border-indigo-300 hover:bg-slate-50'
                  }`}
                >
                  <span className="w-6 h-6 flex-shrink-0 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center text-xs font-bold">
                    {p.id}
                  </span>
                  <span className="font-bold">{p.title}</span>
                </button>
              ))}
            </div>

            <div className="mt-10 flex justify-between">
              <button 
                onClick={goBackQuiz}
                disabled={isCorrect}
                className="px-6 py-3 border-2 border-slate-200 rounded-xl font-bold text-slate-500 hover:bg-slate-50 flex items-center gap-2"
              >
                <ArrowLeft className="w-4 h-4" /> 뒤로 가기
              </button>
              {isCorrect && (
                <button 
                  onClick={nextQuestion}
                  className="px-10 py-3 bg-indigo-600 text-white rounded-xl font-bold text-lg hover:bg-indigo-700 shadow-lg"
                >
                  {currentQuestionIndex < quizData.length - 1 ? '다음 문제' : '결과 확인'}
                </button>
              )}
            </div>
          </div>
        )}

        {/* View: Result */}
        {view === 'result' && (
          <div className="p-12 text-center">
            <div className="w-24 h-24 bg-yellow-100 text-yellow-600 rounded-full flex items-center justify-center mx-auto mb-6">
              <Trophy className="w-12 h-12" />
            </div>
            <h2 className="text-3xl font-extrabold text-slate-800 mb-2">챌린지 완료!</h2>
            <p className="text-slate-500 mb-8">{userInfo.studentId} {userInfo.name}님, 수고하셨습니다.</p>
            
            <div className="bg-slate-50 rounded-3xl p-8 mb-8 inline-block min-w-[300px]">
              <p className="text-slate-600 mb-1 font-medium">최종 획득 점수</p>
              <p className="text-6xl font-black text-indigo-600 font-mono">{totalScore}</p>
              <p className="text-sm text-slate-400 mt-2">만점: {quizData.length * 30}점</p>
            </div>

            <div className="space-y-4">
              <p className="text-slate-600">
                {totalScore >= 120 ? "대단해요! 당신은 신뢰할 수 있는 상위 1% 팩트체커입니다." : 
                 totalScore >= 80 ? "좋은 통찰력을 가졌네요! 조금만 더 신중하면 완벽합니다." :
                 "팩트체크 원칙을 한 번 더 복습하고 도전해보는 건 어떨까요?"}
              </p>
              <div className="flex gap-4 justify-center">
                <button 
                  onClick={() => {
                    setView('learning');
                    setTotalScore(0);
                    setCurrentQuestionIndex(0);
                    setAttempts(1);
                    setIsCorrect(false);
                    setQuizFeedback(null);
                  }}
                  className="px-8 py-3 bg-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-300 transition-all"
                >
                  다시 학습하기
                </button>
                <button 
                  onClick={() => window.location.reload()}
                  className="px-8 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition-all"
                >
                  처음부터 다시하기
                </button>
              </div>
            </div>
          </div>
        )}

      </div>

      <footer className="mt-8 text-center text-slate-400 text-sm">
        <p>© 2024 Media Literacy Challenge. 가짜 뉴스로부터 세상을 지키는 당신의 힘.</p>
      </footer>
    </div>
  );
};

export default App;
